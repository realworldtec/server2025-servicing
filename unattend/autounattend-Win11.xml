<?xml version="1.0" encoding="utf-8"?>
<!--
  autounattend-Win11.xml  -  unattended Windows 11 install for an ESXi VM with NO vTPM.

  WHAT IT DOES
    * windowsPE pass: writes the LabConfig bypass keys BEFORE Setup runs its compatibility
      check, so Setup does NOT stop on "This PC can't run Windows 11" (no TPM 2.0, no Secure
      Boot, insufficient RAM). This is the same bypass Rufus applies to USB media.
    * Wipes disk 0 (via diskpart) and lays down a clean UEFI/GPT layout with a DEDICATED recovery
      partition: EFI 512 MB + MSR 16 MB + Windows (balance) + Recovery 1026 MB. Whether a further
      128 GB is left UNALLOCATED for a Linux dual-boot is chosen AT BOOT by the Ventoy variable
      RESERVESPACE (1 = reserve, 0 = Windows takes the whole disk). Portable to any disk size.
    * Ventoy variable substitution, prompted at boot (names written here WITHOUT their $-delimiters
      on purpose, so Ventoy only substitutes where they are functional, never in this comment):
      COMPUTERNAME, ADMINUSER, ADMINDISPLAYNAME, ADMINPWD, RESERVESPACE. See docs/VENTOY.md.
      Nothing sensitive is stored in this file - the password only exists in Ventoy's in-memory copy.
    * Installs the edition selected BY NAME (default: Windows 11 Pro) - name, not index,
      so this file keeps working whether the media is trimmed (renumbered) or full.
    * Skips OOBE: no Microsoft account, no "let's connect you to a network" - creates a LOCAL
      administrator instead.

  WHAT IT DOES NOT DO
    * It does NOT debloat. Do that AFTER install with Winhance (post-install GUI) or bake it in
      with UnattendedWinstall's generator. Keeping debloat out of here keeps this file small,
      auditable, and safe to reuse. See docs/UNATTEND-Win11-ESXi.md.
    * It cannot add missing CPU instructions (POPCNT / SSE4.2). Not a concern on ESXi 8 - any
      host CPU that runs ESXi 8 has them.

  HARD RULES BEFORE YOU USE IT
    1. It WIPES DISK 0 with no prompt. Only attach it to a VM you intend to install fresh.
    2. Change the local Administrator password below (search: CHANGE-ME).
    3. Set your TimeZone (search: TimeZone) - the value must be a valid Windows TZ id.
    4. UEFI firmware only. In the ESXi VM options set Boot Firmware = EFI (Win11 requires it).

  HOW SETUP FINDS THIS FILE
    Windows Setup auto-reads "autounattend.xml" from the ROOT of any attached removable/optical
    media. Simplest: put this file on a tiny second ISO and attach it as a 2nd CD-ROM. See the
    doc for the one-line oscdimg command. (Do NOT bake it into your golden patched ISO - that
    would wipe disk 0 on every use of that media.)

  Verified against the bypass method current for Windows 11 24H2 / 25H2 (July 2026).
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ============================================================= -->
  <!--  windowsPE : bypass checks, wipe + partition, choose edition  -->
  <!-- ============================================================= -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <!-- The bypass. These keys are read by Setup's compatibility gate; setting them here,
           first, is what lets a no-vTPM ESXi VM install Windows 11 at all. -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!-- Belt-and-braces for the in-place-upgrade path; harmless on a clean install. -->
        <RunSynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\MoSetup" /v AllowUpgradesWithUnsupportedTPMOrCPU /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>

        <!-- Partition disk 0 for a DEDICATED RECOVERY layout, via diskpart. This replaces a
             <DiskConfiguration> block because pure DiskConfiguration cannot set the recovery
             partition's GPT attributes (hidden + platform-required). RunSynchronous in windowsPE
             runs BEFORE the image is applied, so InstallTo (PartitionID 3) targets the Windows
             partition this creates. Portable to any disk size.

             TWO LAYOUTS are written below, and RESERVESPACE picks one at boot (Order 9):
               A (RESERVESPACE=1)  EFI 512 | MSR 16 | Windows (balance) | Recovery 1026 MB | 128 GB FREE
                                   shrink desired=132098 minimum=132096  (=131072 for Linux + 1026)
                                   create partition primary size=1026    (recovery FIXED, so the
                                                                          128 GB is what's left over)
               B (RESERVESPACE=0)  EFI 512 | MSR 16 | Windows (balance) | Recovery 1026 MB   (no free)
                                   shrink desired=1026 minimum=1024
                                   create partition primary             (recovery takes the freed 1 GB)
             Recovery sits immediately after C: in both, which is what WinRE servicing wants.
             To change the reserve to N GB, edit layout A: shrink desired=(N*1024+1026),
             minimum=(N*1024+1024); leave 'size=1026' alone.
             *** WIPES DISK 0. *** -->
        <RunSynchronousCommand wcm:action="add">
          <Order>7</Order>
          <Path>cmd /c (echo select disk 0&amp;echo clean&amp;echo convert gpt&amp;echo create partition efi size=512&amp;echo format quick fs=fat32 label=System&amp;echo create partition msr size=16&amp;echo create partition primary&amp;echo shrink desired=132098 minimum=132096&amp;echo format quick fs=ntfs label=Windows&amp;echo create partition primary size=1026&amp;echo format quick fs=ntfs label=Recovery&amp;echo set id="de94bba4-06d1-4d40-a16a-bfd50179d6ac"&amp;echo gpt attributes=0x8000000000000001)&gt;X:\dp_reserve.txt</Path>
          <Description>Write layout A: EFI/MSR/Windows/Recovery + 128 GB reserved (RESERVESPACE=1)</Description>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>8</Order>
          <Path>cmd /c (echo select disk 0&amp;echo clean&amp;echo convert gpt&amp;echo create partition efi size=512&amp;echo format quick fs=fat32 label=System&amp;echo create partition msr size=16&amp;echo create partition primary&amp;echo shrink desired=1026 minimum=1024&amp;echo format quick fs=ntfs label=Windows&amp;echo create partition primary&amp;echo format quick fs=ntfs label=Recovery&amp;echo set id="de94bba4-06d1-4d40-a16a-bfd50179d6ac"&amp;echo gpt attributes=0x8000000000000001)&gt;X:\dp_full.txt</Path>
          <Description>Write layout B: Windows takes the whole disk, no reserve (RESERVESPACE=0)</Description>
        </RunSynchronousCommand>
        <!-- THE SWITCH. Ventoy substitutes the RESERVESPACE variable with what you type at the prompt:
               1 = reserve 128 GB for Linux   |   0 (or anything else) = Windows takes the whole disk
             Both layout scripts are written above unconditionally; this line only CHOOSES one, which
             keeps the single Ventoy variable on its own line (Ventoy allows at most 1 per line) and
             keeps both layouts explicit and reviewable rather than computed.
             FAIL-SAFE: if this file is ever booted WITHOUT the Ventoy template, the token is not
             expanded, the comparison fails, and it falls through to layout B (no reserve) - i.e. the
             conservative default, never a surprise 128 GB hole. -->
        <RunSynchronousCommand wcm:action="add">
          <Order>9</Order>
          <Path>cmd /c if "$$RESERVESPACE$$"=="1" (diskpart /s X:\dp_reserve.txt) else (diskpart /s X:\dp_full.txt)</Path>
          <Description>Apply the selected disk layout (1=reserve 128 GB for Linux, 0=whole disk)</Description>
        </RunSynchronousCommand>
      </RunSynchronous>

      <!-- NOTE: no <DiskConfiguration> here on purpose - the diskpart RunSynchronousCommands above
           own the partitioning (so we can set the recovery partition's GPT attributes, which
           DiskConfiguration can't). InstallTo below targets PartitionID 3 = the Windows partition
           diskpart created. -->
      <ImageInstall>
        <OSImage>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <!-- Select the edition BY NAME so trimming/renumbering the media cannot pick the
               wrong one. Must match an ImageName in the media's install.wim exactly. A single-
               edition deploy ISO from New-DeployableIso.ps1 contains only "Windows 11 Pro";
               the full trimmed 25H2 media also has "Windows 11 Enterprise" and
               "Windows 11 Pro for Workstations". Confirm with ISO_Inventory.ps1.
               IMPORTANT: keep this and the ProductKey below on the SAME edition - a mismatched
               key can trigger an edition switch during Setup. -->
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>Windows 11 Pro</Value>
            </MetaData>
          </InstallFrom>
        </OSImage>
      </ImageInstall>

      <UserData>
        <AcceptEula>true</AcceptEula>
        <!-- KMS client setup key (GVLK) for Windows 11 PRO. These are Microsoft's PUBLIC generic
             keys: they select the edition and suppress the key prompt during Setup, but they do
             NOT activate. Activation happens afterward against your KMS host (or Active Directory-
             Based Activation) - the installed OS shows "Windows is not activated" until it reaches
             the KMS server, which is expected and correct.
             MUST match /IMAGE/NAME above. Common Win11 GVLKs:
               Pro                     W269N-WFGWX-YVC9B-4J6C9-T83GX
               Pro for Workstations    NRG8B-VKK3Q-CXVCJ-9G2XF-6Q84J
               Enterprise              NPPR9-FWDCX-D2C8J-H872K-2YT43
               Education               NW6C2-QMPVW-D7KKK-3GKT6-VCFB2 -->
        <ProductKey>
          <Key>W269N-WFGWX-YVC9B-4J6C9-T83GX</Key>
        </ProductKey>
      </UserData>

    </component>
  </settings>

  <!-- ============================================================= -->
  <!--  specialize : machine name                                    -->
  <!-- ============================================================= -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <!-- Ventoy expands the COMPUTERNAME variable from a boot-time prompt (docs/VENTOY.md), so the machine is
           NAMED DURING SPECIALIZE - no post-install rename + reboot. Name rules: max 15 chars,
           letters/digits/hyphens, no spaces.
           NOTE: if you ever boot this file WITHOUT the Ventoy auto_install template, the token is NOT
           expanded and would be an invalid name - for non-Ventoy media put "*" (random) or a literal
           name here instead. -->
      <ComputerName>$$COMPUTERNAME$$</ComputerName>
    </component>

    <!-- RunSynchronous lives on Microsoft-Windows-DEPLOYMENT, NOT Shell-Setup. Putting it under
         Shell-Setup makes Setup reject the whole answer file at specialize with 0x80220001
         ("Setting is not defined in this component") and loop forever. This is the documented
         home for a specialize-pass command (system context):
         learn.microsoft.com/.../unattend/microsoft-windows-deployment-runsynchronous -->
    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <!-- Run the privacy hardening HERE, in specialize, as SYSTEM, BEFORE OOBE/first logon.
           This is the universal trigger: it needs no AutoLogon and works on machines with an OEM
           key in firmware (the Acer), where SetupComplete.cmd would be SKIPPED. It is SELF-
           GUARDING: if the hardening script isn't on the media (e.g. plain stock media + this
           answer file), it is a no-op. New-DeployableIso.ps1 injects the script to that path. The
           script's own marker makes it safe even if SetupComplete.cmd also runs it. -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>cmd /c (if exist C:\Windows\Setup\Scripts\Invoke-PrivacyHardening.ps1 (powershell.exe -NoProfile -ExecutionPolicy Bypass -File C:\Windows\Setup\Scripts\Invoke-PrivacyHardening.ps1)) ^&amp; exit /b 0</Path>
          <Description>Privacy hardening (self-guarding; SYSTEM; pre-OOBE)</Description>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>

  <!-- ============================================================= -->
  <!--  oobeSystem : skip OOBE, create a LOCAL admin, set locale     -->
  <!-- ============================================================= -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <!-- HideOnlineAccountScreens + a LocalAccount below is the reliable way to skip the
             Microsoft-account / network gate on 24H2/25H2 (bypassnro.cmd was removed). Microsoft
             keeps tightening OOBE, so if a future build still forces the network page, at that
             screen press Shift+F10 and run: start ms-cxh:localonly -->
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>$$ADMINUSER$$</Name>
            <Group>Administrators</Group>
            <DisplayName>$$ADMINDISPLAYNAME$$</DisplayName>
            <!-- Ventoy prompts for the password at boot and substitutes it into its IN-MEMORY copy of
                 this file, so NO cleartext credential is stored anywhere - not in git, not on the
                 stick. PlainText stays true because the value only ever exists in that copy. -->
            <Password>
              <Value>$$ADMINPWD$$</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <!-- TimeZone: MUST be a valid Windows time-zone id (run `tzutil /l` to list).
           Examples: "Eastern Standard Time", "Central Standard Time", "UTC". -->
      <TimeZone>Eastern Standard Time</TimeZone>

      <!-- Optional: uncomment to auto-log in the local admin once, e.g. to run a post-install
           script. Remove after first boot for security.
      <AutoLogon>
        <Enabled>true</Enabled>
        <LogonCount>1</LogonCount>
        <Username>$$ADMINUSER$$</Username>
        <Password><Value>$$ADMINPWD$$</Value><PlainText>true</PlainText></Password>
      </AutoLogon>
      -->

      <!-- Optional: light first-logon touches. Keep heavy debloat in Winhance instead.
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>powercfg /setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c</CommandLine>
          <Description>High performance power plan</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
      -->

    </component>
  </settings>

</unattend>
