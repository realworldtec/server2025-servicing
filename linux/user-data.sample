#cloud-config
# ================================================================================================
# *** THIS IS THE COMMITTED SAMPLE (user-data.sample). Safe to keep in git. ***
# It contains ONLY placeholders - no real password hash, no real SSH keys.
# To use it, once:
#     cp linux/user-data.sample linux/user-data
# then fill in the real password hash + SSH keys in linux/user-data (which is .gitignore'd) and copy
# THAT file to the stick as /ventoy/autoinstall/user-data. See docs/SSH-KEYS.md and docs/VENTOY.md.
# ================================================================================================
# =====================================================================================
# Ubuntu 26.04 LTS - autoinstall (Subiquity/cloud-init) user-data
# Dual-boot install ALONGSIDE Windows 11 on the Acer Copilot+ (Intel Core Ultra 9 288V,
# "Lunar Lake"). Installs into the 128 GB left UNALLOCATED by the Windows answer file
# (unattend/autounattend-Win11.xml).
#
# HOW IT'S DELIVERED
#   - Ventoy Auto Installation plugin (see linux/ventoy.json), OR
#   - a NoCloud volume/partition labelled 'cidata' holding THIS file (as user-data) plus
#     linux/meta-data. Boot the Ubuntu ISO with the kernel arg  autoinstall  added.
#
# *** STORAGE IS INTENTIONALLY LEFT INTERACTIVE. ***
#   This file automates EVERYTHING except disk partitioning. You partition BY HAND in the
#   installer - into the 128 GB free space, reusing the existing EFI partition - so there
#   is ZERO chance the automation reformats disk 0 and wipes Windows. A fully-automated
#   storage layout that "preserves Windows" is the one piece that cannot be verified
#   without booting the exact hardware, and getting it wrong destroys the Windows install.
#   The click-through for the storage screen is in linux/README-dualboot.md.
#
# BEFORE YOU USE IT
#   1. Set 'timezone' below.
#   2. Replace the PLACEHOLDER password hash under 'identity' (instructions inline).
#   3. Paste your SSH key material (see docs/SSH-KEYS.md).
#
# VENTOY VARIABLES - prompted at boot, exactly like the Windows answer file:
#   HOSTNAME, LINUXREALNAME, LINUXUSER
#   (written here WITHOUT their $-delimiters on purpose, so Ventoy substitutes them only where they
#   are functional and never inside this comment. Ventoy allows at most ONE variable per line.)
#   The password is NOT parametrised - Subiquity needs a pre-computed crypt hash; see the note inline.
#
# *** THIS FILE IS .gitignore'd *** - it carries your PRIVATE SSH key. The committed template is
# user-data.sample. Copy it to 'user-data', fill in the secrets, and put THAT copy on the stick.
# =====================================================================================
autoinstall:
  version: 1

  # Stop ONLY on the storage screen; every other section runs unattended. If you later
  # validate a fully-automated layout on this exact machine, remove 'storage' from here
  # and add a 'storage:' section - but not before (see the note above).
  interactive-sections:
    - storage

  # ---- localisation ----
  locale: en_US.UTF-8
  keyboard:
    layout: us
  timezone: America/New_York          # <-- SET YOUR TIMEZONE (e.g. America/Chicago)

  # ---- primary user ----
  identity:
    # Ventoy substitutes these at boot, exactly like the Windows answer file. Quoted so that whatever
    # you type stays a valid YAML scalar. (One variable per line - Ventoy's hard rule.)
    hostname: "$$HOSTNAME$$"
    realname: "$$LINUXREALNAME$$"
    username: "$$LINUXUSER$$"
    # HASHED password (SHA-512 crypt). This is the ONE field that does NOT Ventoy-parametrise well:
    # Subiquity requires a pre-computed crypt hash, and typing a 100-char $6$... string at a boot
    # prompt is miserable. So set it here, in your gitignored real user-data. A hash is not
    # cleartext, and it contains no "$$" pair, so Ventoy leaves it alone.
    #   Generate:  openssl passwd -6       (or)  mkpasswd --method=SHA-512
    # If you really want it prompted, delete this hash and use cloud-init chpasswd instead - add to
    # the user-data: block below:   chpasswd: {list: "<LINUXUSER>:<LINUXPWD>", expire: false}
    # ...but that needs 2 variables on one line (not allowed), so split it, and note the plaintext
    # then lands in the installed system's cloud-init logs. The hash below is the safer default.
    # The value below is a NON-WORKING placeholder - REPLACE IT before first use.
    password: "__PASSWORD_HASH__"

  # ---- SSH server + INBOUND keys (so you can SSH INTO this box) ----
  ssh:
    install-server: true
    allow-pw: true                     # keep password login as a fallback; set false to force keys
    authorized-keys:
      # PASTE your PUBLIC key(s) allowed to log in. Replace the placeholder line(s).
      - "__AUTHORIZED_KEYS__"

  # ---- OUTBOUND identity keypair, written into the user's ~/.ssh on first boot ----
  # This is cloud-init config applied to the INSTALLED system (not the installer). It drops your
  # private+public key into ~/.ssh so this machine can SSH OUT (git, servers). Replace BOTH blocks
  # with your real key material. Keep the private key secret - this file lives on the stick, not git.
  # NOTE on 'owner:' - it is deliberately absent. It would need the username TWICE on one line
  # ("owner: user:user"), and Ventoy allows at most ONE variable per line. Ownership is therefore
  # set entirely by the runcmd below, which reuses a shell variable to stay within that rule.
  user-data:
    write_files:
      - path: /home/$$LINUXUSER$$/.ssh/__KEY_ID__
        permissions: '0600'
        defer: true                    # write after the user account exists
        content: |
          __PRIVATE_KEY__
      - path: /home/$$LINUXUSER$$/.ssh/__KEY_ID__.pub
        permissions: '0644'
        defer: true
        content: '__PUBLIC_KEY__'
    runcmd:
      # Guarantees the dir/ownership/perms sshd's StrictModes requires. Ventoy substitutes the ONE
      # variable, then the shell reuses it as $U - that is how we stay at one variable per line.
      - [ bash, -c, "U=$$LINUXUSER$$; install -d -m 700 -o $U -g $U /home/$U/.ssh; chmod 600 /home/$U/.ssh/__KEY_ID__; chmod 644 /home/$U/.ssh/__KEY_ID__.pub; chown -R $U:$U /home/$U/.ssh" ]

  # ---- network: DHCP is automatic. Use the USB-Ethernet you tested during install;
  #      Wi-Fi during autoinstall is unreliable. Nothing to configure here for DHCP. ----

  # ---- extra packages on top of the base desktop ----
  packages:
    - linux-firmware        # Wi-Fi 7 / Bluetooth / GPU firmware blobs for Lunar Lake
    - os-prober             # lets GRUB detect the Windows Boot Manager

  # ---- don't let the installer self-update mid-run (keeps the build deterministic) ----
  refresh-installer:
    update: false

  # ---- wire up dual-boot in the freshly-installed system ----
  # late-commands run in the live installer with the new system mounted at /target.
  late-commands:
    # Ubuntu ships os-prober DISABLED since 20.04; enable it so GRUB adds a Windows entry.
    - echo 'GRUB_DISABLE_OS_PROBER=false' >> /target/etc/default/grub
    # Regenerate the GRUB menu inside the target so "Windows Boot Manager" appears.
    - curtin in-target --target=/target -- update-grub

  # ---- reboot when finished (pull the USB at the "please remove medium" prompt) ----
  shutdown: reboot
